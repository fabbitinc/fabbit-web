{
  "name": "fabbit-web",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.15.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@fabbit/web",
    "dev2": "turbo run dev --filter=@fabbit/web2",
    "build": "turbo run build --filter=@fabbit/web",
    "lint": "turbo run lint --filter=@fabbit/web",
    "dev:web2": "turbo run dev --filter=@fabbit/web2",
    "build:web2": "turbo run build --filter=@fabbit/web2",
    "lint:web2": "turbo run lint --filter=@fabbit/web2",
    "storybook": "turbo run storybook --filter=@fabbit/storybook",
    "build-storybook": "turbo run build-storybook --filter=@fabbit/storybook"
  },
  "devDependencies": {
    "turbo": "^2.8.11"
  }
}
