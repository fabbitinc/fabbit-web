{
  "name": "fabbit-web",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.15.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@fabbit/web",
