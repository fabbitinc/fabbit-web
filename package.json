{
  "name": "fabbit-web",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.15.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@fabbit/web",
    "build": "turbo run build --filter=@fabbit/web",
    "lint": "turbo run lint --filter=@fabbit/web",
    "dev:landing": "turbo run dev --filter=@fabbit/landing",
    "build:landing": "turbo run build --filter=@fabbit/landing",
    "storybook": "turbo run storybook --filter=@fabbit/storybook",
    "build-storybook": "turbo run build-storybook --filter=@fabbit/storybook"
  },
  "devDependencies": {
    "turbo": "^2.8.20"
  },
  "pnpm": {
    "overrides": {
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3"
    }
  }
}
